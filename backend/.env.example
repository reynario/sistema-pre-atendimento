# Banco de dados (docker-compose local ou Hetzner)
DATABASE_URL="postgresql://alo:alo_dev_password@localhost:5432/alo"

# Redis (filas de lembretes/follow-ups/debounce)
REDIS_URL="redis://localhost:6379"

# Segredo do JWT (troque em produção!)
JWT_SECRET="troque-este-segredo-em-producao"

# Porta do servidor
PORT=3333

# URL pública do backend (usada para montar a URL de webhook mostrada no painel)
PUBLIC_URL="http://localhost:3333"

# ---------- IA ----------
# Chave da API da OpenAI (IA SDR + transcrição de áudio com Whisper)
OPENAI_API_KEY=""
# Modelo usado pela IA de atendimento
OPENAI_MODEL="gpt-4o-mini"

# ---------- UazAPI ----------
# URL base do seu servidor UazAPI (ex: https://SEU-SUBDOMINIO.uazapi.com)
UAZAPI_BASE_URL=""
# Token admin da UazAPI (opcional, para criar instâncias via API)
UAZAPI_ADMIN_TOKEN=""

# CORS: origem do frontend (Cloudflare Workers em produção)
FRONTEND_ORIGIN="http://localhost:5173"

# ---------- Web push (notificações no celular) ----------
# Gere o par de chaves com: npx web-push generate-vapid-keys
# Sem as chaves, o push fica desligado (o painel continua com polling)
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:rndigitalmidia@gmail.com"

# ---------- Admin da plataforma ----------
# E-mails (separados por vírgula) que enxergam o painel /admin:
# clientes, aprovação de cadastros, receita, tokens e cupons
ADMIN_EMAILS="rndigitalmidia@gmail.com"
